---
import { siteConfig } from "../config";
---

<section id="experience" class="py-20 md:py-28 bg-[var(--color-surface)]">
  <div class="max-w-4xl mx-auto px-6">
    <h2 class="reveal text-2xl md:text-3xl text-[var(--color-primary-dark)] mb-12">Experience</h2>

    <div class="space-y-10">
      {siteConfig.experience.map((exp, i) => (
        <div class={`reveal stagger-${Math.min(i + 1, 4)} timeline-item pb-8`}>
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-3">
            <div>
              <h3 class="text-base md:text-lg font-semibold text-[var(--color-primary-dark)] font-['Inter']">{exp.org}</h3>
              <p class="text-sm text-[var(--color-primary)] font-medium">{exp.role}</p>
              {exp.program && <p class="text-xs text-gray-400 mt-0.5">{exp.program}</p>}
            </div>
            <div class="text-xs text-gray-400 sm:text-right flex-shrink-0">
              <span>{exp.period}</span>
              <br />
              <span>{exp.location}</span>
            </div>
          </div>
          <ul class="space-y-1.5 ml-0">
            {exp.highlights.map((h) => (
              <li class="text-sm text-gray-500 flex items-start gap-2">
                <span class="mt-2 w-1 h-1 rounded-full bg-[var(--color-primary-light)] flex-shrink-0"></span>
                {h}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
