---
import { siteConfig } from "../config";
---

<footer id="contact" class="py-20 md:py-24 bg-[var(--color-primary-dark)] text-white">
  <div class="max-w-4xl mx-auto px-6 text-center">
    <h2 class="reveal text-2xl md:text-3xl font-['DM_Serif_Display'] mb-4">Let's Connect</h2>
    <p class="reveal stagger-1 text-[var(--color-primary-light)] mb-10 max-w-md mx-auto text-sm md:text-base">
      Interested in collaboration, consulting, or speaking engagements? I'd love to hear from you.
    </p>

    <div class="reveal stagger-2 flex justify-center gap-4 mb-10">
      <a href={`mailto:${siteConfig.social.email}`}
         class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-white text-[var(--color-primary-dark)] text-sm font-medium hover:bg-[var(--color-surface)] transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        Email Me
      </a>
      <a href={siteConfig.social.linkedin} target="_blank" rel="noopener"
         class="inline-flex items-center justify-center w-12 h-12 rounded-full border border-[var(--color-primary-light)]/40 text-[var(--color-primary-light)] hover:bg-white/10 transition-colors" aria-label="LinkedIn">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <a href={siteConfig.social.scholar} target="_blank" rel="noopener"
         class="inline-flex items-center justify-center w-12 h-12 rounded-full border border-[var(--color-primary-light)]/40 text-[var(--color-primary-light)] hover:bg-white/10 transition-colors" aria-label="Google Scholar">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 100 14 7 7 0 000-14z"/></svg>
      </a>
    </div>

    <div class="reveal stagger-3 text-xs text-[var(--color-primary-light)]/60">
      <p>Washington, D.C.</p>
      <p class="mt-2">Made with care by <a href="https://cofoundy.dev" target="_blank" rel="noopener" class="text-[var(--color-primary-light)]/80 hover:text-white transition-colors">Cofoundy</a></p>
    </div>
  </div>
</footer>
