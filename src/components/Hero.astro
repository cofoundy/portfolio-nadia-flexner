---
import { siteConfig } from "../config";
---

<section id="hero" class="min-h-screen flex items-center bg-[var(--color-surface-light)] pt-16 md:pt-0">
  <div class="max-w-6xl mx-auto px-6 py-16 md:py-24">
    <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">
      <!-- Photo -->
      <div class="hero-photo flex-shrink-0">
        <div class="w-48 h-48 md:w-64 md:h-64 rounded-2xl overflow-hidden border-4 border-white shadow-xl">
          <img
            src={`${import.meta.env.BASE_URL}profile.png`}
            alt={siteConfig.name}
            class="w-full h-full object-cover"
            width="256"
            height="256"
          />
        </div>
      </div>

      <!-- Text -->
      <div class="text-center md:text-left">
        <h1 class="hero-title text-3xl sm:text-4xl md:text-5xl text-[var(--color-primary-dark)] leading-tight">
          {siteConfig.name}
        </h1>
        <p class="hero-subtitle mt-2 text-lg md:text-xl text-[var(--color-primary)] font-medium">
          {siteConfig.credentials}
        </p>
        <p class="hero-description mt-1 text-base md:text-lg text-gray-600">
          {siteConfig.title} · <span class="text-[var(--color-primary)]">{siteConfig.organization}</span>
        </p>
        <p class="hero-cta mt-4 text-base md:text-lg text-gray-500 italic max-w-xl font-['DM_Serif_Display']">
          "{siteConfig.tagline}"
        </p>

        <!-- Stats -->
        <div class="hero-stats mt-8 flex flex-wrap justify-center md:justify-start gap-6 md:gap-8">
          {siteConfig.stats.map((stat) => (
            <div class="text-center">
              <div class="text-2xl md:text-3xl font-bold text-[var(--color-accent)]">{stat.value}</div>
              <div class="text-xs text-gray-500 mt-1 uppercase tracking-wider">{stat.label}</div>
            </div>
          ))}
        </div>

        <!-- Social -->
        <div class="hero-social mt-8 flex justify-center md:justify-start gap-4">
          <a href={`mailto:${siteConfig.social.email}`} class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--color-primary-dark)] text-white text-sm font-medium hover:bg-[var(--color-primary)] transition-colors" aria-label="Email">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            Contact
          </a>
          <a href={siteConfig.social.linkedin} target="_blank" rel="noopener" class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-[var(--color-primary-light)] text-[var(--color-primary)] hover:bg-[var(--color-surface)] transition-colors" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href={siteConfig.social.scholar} target="_blank" rel="noopener" class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-[var(--color-primary-light)] text-[var(--color-primary)] hover:bg-[var(--color-surface)] transition-colors" aria-label="Google Scholar">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 100 14 7 7 0 000-14z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
