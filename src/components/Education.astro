---
import { siteConfig } from "../config";
---

<section class="py-20 md:py-28 bg-white">
  <div class="max-w-4xl mx-auto px-6">
    <h2 class="reveal text-2xl md:text-3xl text-[var(--color-primary-dark)] mb-12">Education & Awards</h2>

    <!-- Education cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-14">
      {siteConfig.education.map((edu, i) => (
        <div class={`reveal stagger-${i + 1} p-6 rounded-xl bg-[var(--color-surface-light)] border border-[var(--color-primary-light)]/20 card-hover`}>
          <div class="text-2xl font-bold text-[var(--color-accent)] font-['DM_Serif_Display']">{edu.degree}</div>
          <div class="mt-2 text-sm font-semibold text-[var(--color-primary-dark)] font-['Inter']">{edu.field}</div>
          <div class="mt-1 text-sm text-gray-500">{edu.school}</div>
          <div class="mt-1 text-xs text-gray-400">{edu.location}</div>
          {edu.supervisor && (
            <div class="mt-3 text-xs text-[var(--color-primary)]">Supervisor: {edu.supervisor}</div>
          )}
        </div>
      ))}
    </div>

    <!-- Awards -->
    <div class="reveal">
      <h3 class="text-sm font-semibold text-[var(--color-primary)] uppercase tracking-wider mb-4 font-['Inter']">Awards</h3>
      <div class="space-y-3">
        {siteConfig.awards.map((award) => (
          <div class="flex items-start gap-3 text-sm">
            <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] flex-shrink-0"></span>
            <div>
              <span class="text-[var(--color-primary-dark)] font-medium">{award.name}</span>
              {award.org && <span class="text-gray-400"> · {award.org}</span>}
              <span class="text-gray-400"> · {award.year}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Conferences -->
    <div class="reveal mt-14">
      <h3 class="text-sm font-semibold text-[var(--color-primary)] uppercase tracking-wider mb-4 font-['Inter']">Selected Conferences</h3>
      <div class="flex flex-wrap gap-2">
        {siteConfig.conferences.map((conf) => (
          <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs bg-white border border-[var(--color-primary-light)]/30 text-gray-500">
            {conf.event} · {conf.location} ({conf.year})
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
